<form class="aidm-actor-gen-form standard-form">

  <div class="form-group">
    <label>{{localize "AIDM.ActorGen.Concept.Label"}}</label>
    <div class="form-fields">
      <textarea name="concept" rows="3"
        placeholder="{{localize "AIDM.ActorGen.Concept.Placeholder"}}"></textarea>
    </div>
    <p class="hint">{{localize "AIDM.ActorGen.Concept.Hint"}}</p>
  </div>

  <div class="form-group">
    <label>{{localize "AIDM.ActorGen.CR.Label"}}</label>
    <div class="form-fields">
      <select name="cr">
        {{#each crOptions}}
        <option value="{{this.value}}"{{#if (eq this.value "1")}} selected{{/if}}>CR {{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "AIDM.ActorGen.Role.Label"}}</label>
    <div class="form-fields">
      <select name="role">
        {{#each roles}}
        <option value="{{this.id}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    <p class="hint">{{localize "AIDM.ActorGen.Role.Hint"}}</p>
  </div>

  <div class="form-group">
    <label>{{localize "AIDM.ActorGen.SpawnCount.Label"}}</label>
    <div class="form-fields">
      <input type="number" name="spawnCount" value="0" min="0" max="20" step="1" />
    </div>
    <p class="hint">{{localize "AIDM.ActorGen.SpawnCount.Hint"}}</p>
  </div>

  <footer class="sheet-footer">
    <button type="button" data-action="generate">
      <i class="fa-solid fa-person-rays"></i>
      {{localize "AIDM.ActorGen.Generate"}}
    </button>
  </footer>

</form>
