<form class="aidm-actor-gen-form standard-form">

  <div class="form-group">
    <label>NPC Concept</label>
    <div class="form-fields">
      <textarea name="concept" rows="3"
        placeholder="A tiefling warlock enforcer working for the Crimson Hand thieves guild…"></textarea>
    </div>
    <p class="hint">Include personality, role, any specific traits you want. The AI builds the stat block.</p>
  </div>

  <div class="form-group">
    <label>Challenge Rating</label>
    <div class="form-fields">
      <select name="cr">
        {{#each crOptions}}
        <option value="{{this.value}}"{{#if (eq this.value "1")}} selected{{/if}}>CR {{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Combat Role</label>
    <div class="form-fields">
      <select name="role">
        {{#each roles}}
        <option value="{{this.id}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    <p class="hint">Shapes the AI's stat allocation and action choices.</p>
  </div>

  <div class="form-group">
    <label>Spawn on Current Scene</label>
    <div class="form-fields">
      <input type="number" name="spawnCount" value="0" min="0" max="20" step="1" />
    </div>
    <p class="hint">Immediately place this many tokens on the active scene. Set 0 to skip.</p>
  </div>

  <footer class="sheet-footer">
    <button type="button" data-action="generate">
      <i class="fa-solid fa-person-rays"></i>
      Generate NPC
    </button>
  </footer>

</form>
