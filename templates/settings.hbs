<form class="aidm-settings-form standard-form">
  <div class="form-group">
    <label>Provider</label>
    <div class="form-fields">
      <select name="provider" id="aidm-provider">
        {{#each providers}}
        <option value="{{this.id}}"{{#if this.active}} selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Model</label>
    <div class="form-fields">
      <select name="model" id="aidm-model">
        {{#each models}}
        <option value="{{this.id}}"{{#if this.active}} selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>API Key</label>
    <div class="form-fields">
      <input
        type="password"
        name="apiKey"
        id="aidm-apikey"
        value="{{apiKey}}"
        placeholder="Enter API key…"
      />
    </div>
  </div>

  <div class="form-group">
    <label>Combat System</label>
    <div class="form-fields">
      <select name="combatSystem" id="aidm-combat-system">
        {{#each combatSystems}}
        <option value="{{this.id}}"{{#if this.active}} selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    <p class="hint">Override auto-detection if you are using a custom system adapter.</p>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="button" data-action="testConnection">
      <i class="fa-solid fa-plug-circle-check"></i>
      Test Connection
    </button>
    <button type="button" data-action="save">
      <i class="fa-solid fa-floppy-disk"></i>
      Save
    </button>
  </footer>
</form>
