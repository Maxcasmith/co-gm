<form class="aidm-world-gen-form standard-form">
  <div class="form-group">
    <label>Campaign Name</label>
    <div class="form-fields">
      <input
        type="text"
        name="campaignName"
        value="{{campaignName}}"
        placeholder="e.g. The Age of Ash"
        required
      />
    </div>
  </div>

  <div class="form-group">
    <label>Theme &amp; Setting</label>
    <div class="form-fields">
      <textarea name="theme" rows="3"
        placeholder="Dark medieval fantasy, post-apocalyptic magic, pirate seas…">{{theme}}</textarea>
    </div>
    <p class="hint">Be as specific or broad as you like — the AI fills in the gaps.</p>
  </div>

  <div class="form-group">
    <label>Tone</label>
    <div class="form-fields">
      <select name="tone">
        {{#each tones}}
        <option value="{{this.value}}"{{#if this.active}} selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Game System</label>
    <div class="form-fields">
      <input type="text" name="gameSystem" value="{{gameSystem}}" />
    </div>
  </div>

  <div class="form-group">
    <label>Number of Players</label>
    <div class="form-fields">
      <input type="number" name="playerCount" value="{{playerCount}}" min="1" max="8" />
    </div>
  </div>

  <div class="form-group">
    <label>Session Zero Notes</label>
    <div class="form-fields">
      <textarea name="sessionZeroNotes" rows="4"
        placeholder="Backstory elements, things to avoid, specific requests…">{{sessionZeroNotes}}</textarea>
    </div>
    <p class="hint">Optional. Anything the AI should know before generating.</p>
  </div>

  <footer class="sheet-footer">
    <button type="button" data-action="generate" class="bright">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
      Generate World
    </button>
  </footer>
</form>
