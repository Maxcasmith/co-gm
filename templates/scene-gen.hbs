<form class="aidm-scene-gen-form standard-form">

  <div class="form-group">
    <label>Scene Name</label>
    <div class="form-fields">
      <input type="text" name="sceneName"
        placeholder="e.g. The Obsidian Vault" />
    </div>
  </div>

  <div class="form-group">
    <label>Description</label>
    <div class="form-fields">
      <textarea name="description" rows="4"
        placeholder="A flooded tomb beneath the city sewers, the air thick with alchemical fumes…"></textarea>
    </div>
    <p class="hint">Describe the location — the AI fills in atmosphere, lighting, and layout suggestions.</p>
  </div>

  <div class="form-group">
    <label>Scene Type</label>
    <div class="form-fields">
      <select name="sceneType">
        {{#each sceneTypes}}
        <option value="{{this.id}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Map Size</label>
    <div class="form-fields">
      <select name="size">
        {{#each sizes}}
        <option value="{{this.id}}"{{#if this.active}} selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Lighting</label>
    <div class="form-fields">
      <select name="lighting">
        {{#each lightings}}
        <option value="{{this.id}}"{{#if this.active}} selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Light Sources</label>
    <div class="form-fields">
      <input type="number" name="lightCount" value="3" min="0" max="12" step="1" />
    </div>
    <p class="hint">Number of ambient lights the AI will place on the scene (0–12).</p>
  </div>

  <footer class="sheet-footer">
    <button type="button" data-action="generate">
      <i class="fa-solid fa-map"></i>
      Generate Scene
    </button>
  </footer>

</form>
